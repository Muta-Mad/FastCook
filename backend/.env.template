# ── Database ──────────────────────────────────────────────────────────────────
DB__URL=postgresql+asyncpg://postgres:password@db:5432/fastcook

# ── Auth tokens ───────────────────────────────────────────────────────────────
ACCESS_TOKEN__VERIFICATION_TOKEN_SECRET=change-me-to-a-long-random-string
ACCESS_TOKEN__RESET_PASSWORD_TOKEN_SECRET=change-me-to-another-long-random-string
ACCESS_TOKEN__LIFETIME_SECONDS=3600

# ── App ───────────────────────────────────────────────────────────────────────
APP__DEBUG=false
APP__HOST=0.0.0.0
APP__PORT=8000
APP__RELOAD=false

# ── CORS ──────────────────────────────────────────────────────────────────────
# In production replace * with your actual frontend origin:
# CORS__ALLOW_ORIGINS=["https://yourdomain.com"]
CORS__ALLOW_ORIGINS=["*"]
CORS__ALLOW_CREDENTIALS=true
CORS__ALLOW_METHODS=["*"]
CORS__ALLOW_HEADERS=["*"]

# ── Pagination ────────────────────────────────────────────────────────────────
PAGINATION__PAGE_SIZE=6

# ── PostgreSQL (used by the db container in docker-compose) ───────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=fastcook
